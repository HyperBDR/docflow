DOCFLOW_SECRET_KEY=change-me-in-production
DOCFLOW_DATABASE_URL=postgresql+psycopg://docflow:docflow@postgres:5432/docflow
DOCFLOW_REDIS_URL=redis://redis:6379/0
DOCFLOW_STORAGE_DIR=/data
DOCFLOW_STORAGE_ALLOWED_ROOTS=/data,/storage-data
DOCFLOW_HOST_STORAGE_DIR=./storage-data
DOCFLOW_PUBLIC_BASE_URL=http://localhost:8001
DOCFLOW_WEB_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:8001
DOCFLOW_EXTENSION_TOKEN_DAYS=180
DOCFLOW_DOM_SLIDES_ENABLED=true
DOCFLOW_RENDER_WEB_URL=http://web
DOCFLOW_CHROMIUM_EXECUTABLE=/usr/bin/chromium
DOCFLOW_MONITORING_INTERVAL_SECONDS=60
DOCFLOW_MONITORING_RETENTION_DAYS=7
# Optional email alert delivery. Webhook alerts do not require these values.
DOCFLOW_SMTP_HOST=
DOCFLOW_SMTP_PORT=587
DOCFLOW_SMTP_USERNAME=
DOCFLOW_SMTP_PASSWORD=
DOCFLOW_SMTP_FROM=
DOCFLOW_SMTP_TLS=true
